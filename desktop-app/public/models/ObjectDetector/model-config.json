{
  "model": "yolov8n",
  "inputSize": 640,
  "confidenceThreshold": 0.25,
  "iouThreshold": 0.7,
  "maxDetections": 300,
  "classes": ["phone"], 
  "training": {
    "epochs": 20,
    "batchSize": 16,
    "optimizer": "Adam",
    "device": "cpu",
    "pretrained": true
  },
  "augmentation": {
    "hsv_h": 0.015,
    "hsv_s": 0.7,
    "hsv_v": 0.4,
    "fliplr": 0.5,
    "translate": 0.1,
    "scale": 0.5
  },
  "paths": {
    "modelPath": "models/ObjectDetector/best.onnx",
    "datasetConfig": "dataset/data.yaml"
  }
}